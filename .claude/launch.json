{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev (Turbopack)",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/opt/homebrew/bin:$PATH pnpm dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Production",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["start"],
      "port": 3000
    }
  ]
}
